{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "outDir": "build",
    "rootDir": "src",
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "moduleResolution": "nodenext",
    "module": "nodenext"
  },
  "include": ["src/**/*"]
}
